# ── Database ───────────────────────────────────────
DB_PASSWORD=flavorverse123

# ── JWT ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-to-random-32char-string

# ── Google OAuth2 ────────────────────────────────────
# Đăng ký tại: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Cloudinary (lưu ảnh) ─────────────────────────────
# Đăng ký tại: https://cloudinary.com (free 25GB)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Groq AI ──────────────────────────────────────────
# Đăng ký tại: https://console.groq.com (free)
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenWeatherMap ───────────────────────────────────
# Đăng ký tại: https://openweathermap.org/api (free)
OPENWEATHER_API_KEY=your-openweather-key

# ── App ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
